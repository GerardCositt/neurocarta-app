APP_NAME="Carta Bar Jaén"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

# Volcado «Carta Bar v2 - Bar Jaén» (coloca el .sql en database/backups/). Si la BD está vacía, «php artisan setup» lo importa.
# CARTA_IMPORT_SQL=database/backups/carta-bar-jaen-v2.sql

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# OpenAI — necesaria para importar carta con IA, descripciones, imágenes y maridajes.
# Obtén una key en https://platform.openai.com/api-keys
# Alternativa: guardar la key solo para tu restaurante en Ajustes → Importar con IA (no usa créditos de plataforma).
OPENAI_API_KEY=

# Si OPENAI_API_KEY está en .env (clave de plataforma), cada restaurante consume «créditos IA» salvo modo demo ilimitado o key propia del cliente.
